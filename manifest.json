{
  "manifest_version": 3,
  "name": "价格计算器",
  "description": "根据拿货价、优惠、运费、退货率、利润和推广 ROI 计算平台价格与成交价。",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "permissions": [
    "sidePanel"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "价格计算器",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
